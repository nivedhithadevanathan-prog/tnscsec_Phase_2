generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id            Int       @id @default(autoincrement())
  username      String?   @db.VarChar(75)
  department_id Int?
  district_id   Int?
  zone_id       String?   @db.VarChar(100)
  fullname      String?   @db.VarChar(100)
  mobile        String?   @db.VarChar(75)
  email         String?   @db.VarChar(100)
  role_id       Int?      @default(3) @db.MediumInt
  is_active     Boolean   @default(true)
  is_deleted    Boolean   @default(false)
  password      String?   @db.VarChar(100)
  created_by    Int?
  created_at    DateTime? @default(now()) @db.DateTime(0)
  updated_by    Int?
  updated_at    DateTime? @db.DateTime(0)

  @@index([fullname], map: "fullname")
  @@index([district_id], map: "jail_id")
  @@index([role_id], map: "role_id")
  @@index([username], map: "username")
}

model zone {
  id        Int     @id @default(autoincrement())
  name      String? @db.VarChar(255)
  is_active Int?    @default(1)
}

model department {
  id        Int     @id @default(autoincrement())
  seo_id    Int?
  jrcs      Int?
  name      String? @db.VarChar(255)
  image     Bytes?  @db.Blob
  is_active Int     @default(1)
}

model district {
  id        Int     @id @default(autoincrement())
  name      String? @db.VarChar(255)
  is_active Int?    @default(1)
}

model master_dist {
  id        Int  @id @default(autoincrement())
  deptid    Int
  distid    Int
  is_active Int? @default(1)
}

model master_zone {
  id               Int     @id @default(autoincrement())
  association_id   Int?
  district_id      Int?
  zone_id          Int?
  association_name String? @db.VarChar(150)
  is_active        Int     @default(1)
}

model reservation {
  id         Int  @id @default(autoincrement())
  rurel_id   Int? @default(0)
  tot_voters Int  @default(0)
  sc_st      Int? @default(0)
  women      Int? @default(0)
  general    Int? @default(0)
  is_active  Int? @default(1)
}

model role {
  id         Int       @id @default(autoincrement())
  name       String?   @db.VarChar(75)
  is_active  Boolean   @default(true)
  is_deleted Boolean   @default(false)
  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
}

model form1 {
  id                     Int                      @id @default(autoincrement())
  uid                    Int
  department_id          Int?
  seo_id                 Int?
  district_id            Int?
  zone_id                Int?
  remark                 String?                  @db.VarChar(150)
  is_active              Int?                     @default(1)
  selected_count         Int?                     @default(0)
  non_selected_count     Int?                     @default(0)
  form1_non_selected_soc form1_non_selected_soc[]
  form1_selected_soc     form1_selected_soc[]
  form2                  form2[]
}

model form1_non_selected_soc {
  id           Int     @id @default(autoincrement())
  form1_id     Int?
  society_id   Int?
  society_name String? @db.VarChar(255)
  sc_st        Int?    @default(0)
  women        Int?    @default(0)
  general      Int?    @default(0)
  tot_voters   Int?    @default(0)
  form1        form1?  @relation(fields: [form1_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "form1_non_selected_soc_ibfk_1")

  @@index([form1_id], map: "form1_id")
}

model form1_selected_soc {
  id           Int     @id @default(autoincrement())
  form1_id     Int?
  society_id   Int?
  society_name String? @db.VarChar(255)
  sc_st        Int?    @default(0)
  women        Int?    @default(0)
  general      Int?    @default(0)
  tot_voters   Int?    @default(0)
  form1        form1?  @relation(fields: [form1_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "form1_selected_soc_ibfk_1")

  @@index([form1_id], map: "form1_id")
}

model form2 {
  id                     Int                      @id @default(autoincrement())
  uid                    Int?
  department_id          Int?
  form1_id               Int
  is_active              Boolean?                 @default(true)
  district_id            Int?
  zone_id                Int?
  masterzone_count       Int?
  remark                 String?                  @db.VarChar(255)
  selected_soc_count     Int?
  form1                  form1                    @relation(fields: [form1_id], references: [id], onUpdate: Restrict, map: "fk_form2_form1")
  form2_non_selected_soc form2_non_selected_soc[]
  form2_selected_soc     form2_selected_soc[]
  form3                  form3[]

  @@index([form1_id], map: "fk_form2_form1")
}

model form2_non_selected_soc {
  id           Int     @id @default(autoincrement())
  form2_id     Int
  society_id   Int
  society_name String? @db.VarChar(255)
  form2        form2   @relation(fields: [form2_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "form2_non_selected_soc_ibfk_1")

  @@index([form2_id], map: "form2_id")
}

model form2_selected_soc {
  id           Int     @id @default(autoincrement())
  form2_id     Int
  society_id   Int
  society_name String? @db.VarChar(255)
  form2        form2   @relation(fields: [form2_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "form2_selected_soc_ibfk_1")

  @@index([form2_id], map: "form2_id")
}

model form3 {
  id                 Int               @id @default(autoincrement())
  uid                Int
  department_id      Int?
  form2_id           Int?
  is_active          Int?              @default(1)
  district_id        Int?
